---
import Layout from "../../layouts/Layout.astro";
import ToneGenSection from "../../components/ToneGen";
import { t, changeLanguage } from "i18next";
import MoreTools from "../../components/MoreTools.astro";

changeLanguage("es");
---

<Layout title={t("432hz.title")} description={t("432hz.description")}>
  <main class="prose mx-auto">
    <h1 class="text-center pt-4">{t("432hz.title")}</h1>

    <ToneGenSection client:idle />
    <MoreTools/>

    <article class="p-4">
      <h2>{t("432hz.howToGenerate.title")}</h2>
      <p>{t("432hz.howToGenerate.content")}</p>
      <h3>{t("432hz.useOfPlayer.title")}</h3>
      <p>{t("432hz.useOfPlayer.content")}</p>

      <h3>{t("432hz.faqs.title")}</h3>
      {
        (
          t("432hz.faqs.questions", {
            returnObjects: true,
          }) as []
        ).map((answer: any, question) => (
          <div class="p-2">
            <div class="collapse bg-base-200 collapse-arrow">
              <input type="checkbox" />
              <div class="collapse-title text-base font-medium">
                {answer.question}
              </div>
              <div class="collapse-content">{answer.answer}</div>
            </div>
          </div>
        ))
      }
    </article>
  </main>
</Layout>
<style is:global>
  .range1.range::-moz-range-thumb {
    box-shadow: none !important;
    background-color: darkgray !important;
  }
  .range1.range::-webkit-slider-thumb {
    box-shadow: none !important;
    background-color: darkgray !important;
  }
  /* Chrome, Safari, Edge, Opera */
  input::-webkit-outer-spin-button,
  input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  /* Firefox */
  input[type="number"] {
    -moz-appearance: textfield;
  }
</style>
