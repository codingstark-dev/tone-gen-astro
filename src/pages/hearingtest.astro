---
import Layout from "../layouts/Layout.astro";
import HearingTest from "../components/HeartingTest";
import { t, changeLanguage } from "i18next";
import MoreTools from "../components/MoreTools.astro";

changeLanguage("en");
---

<Layout title={t("hearing.title")} description={t("hearing.description")}>
  <main class="prose mx-auto">
    <h1 class="text-center pt-4">{t("hearing.heading")}</h1>
    <HearingTest client:idle />
    <MoreTools />

    <article class="p-4">
      <h2>
        {t("hearing.hearingTest.title")}
      </h2>
      <p>{t("hearing.hearingTest.content")}</p>
      <h2>
        {t("hearing.disclaimer.title")}
      </h2>
      <p>{t("hearing.disclaimer.content")}</p>
      <div role="alert" class="alert alert-error my-10">
        <span>{t("hearing.note")}</span>
      </div>

      <h2>
        {t("hearing.howToTakeTest.title")}
      </h2>
      <p>{t("hearing.howToTakeTest.content")}</p>
      <ol>
        <li>{t("hearing.howToTakeTest.steps.visitToneGen")}</li>
        <li>{t("hearing.howToTakeTest.steps.exploreWebsite")}</li>
        <li>{t("hearing.howToTakeTest.steps.checkMenuOptions")}</li>
        <li>{t("hearing.howToTakeTest.steps.followInstructions")}</li>
        <li>{t("hearing.howToTakeTest.steps.completeTest")}</li>
        <li>{t("hearing.howToTakeTest.steps.reviewResults")}</li>
      </ol>

      <h3>FAQ's</h3>
      {
        (
          t("hearing.faqs.questions", {
            returnObjects: true,
          }) as []
        ).map((answer: any, question) => (
          <div class="p-2">
            <div class="collapse bg-base-200 collapse-arrow">
              <input type="checkbox" />
              <div class="collapse-title text-base font-medium">
                {answer.question}
              </div>
              <div class="collapse-content">{answer.answer}</div>
            </div>
          </div>
        ))
      }
    </article>
  </main>
</Layout>
