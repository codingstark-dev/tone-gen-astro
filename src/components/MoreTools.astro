---

<h2 class="text-2xl font-bold mb-2 text-center">More Tone Gen Tools</h2>
<div class="grid grid-cols-2 align-middle gap-3 p-2">
  {
    tools.map((tool) => (
      <a href={localizePath(tool.link)}>
        <div class="btn btn-block  btn-outline shadow-lg bg-base-200 h-auto">
          <div class="bg-slate-50 rounded-lg p-1" set:html={tool.svg} />
          <span class="text-sm">{tool.name}</span>
        </div>
      </a>
    ))
  }
</div>

